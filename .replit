modules = ["nodejs-20", "web", "python-3.12"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
MONGO_URL = "mongodb+srv://clustermd:<3fbNO7pLepq5Wt3u>@cluster0.ykw79pu.mongodb.net/?appName=Cluster0"
MONGO_URI = "mongodb+srv://clustermd:<3fbNO7pLepq5Wt3u>@cluster0.ykw79pu.mongodb.net/?appName=Cluster0"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && node dist/kaoi.js"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
