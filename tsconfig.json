{
  "compilerOptions": {            
    "target": "ES6",                                
    "module": "commonjs",                           
    "lib": [
      "ESNext",
      "DOM"
    ],                                   
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,                                
    "esModuleInterop": true,                        
    "skipLibCheck": true,                          
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": [
    "src/**/*"
  ]
}
